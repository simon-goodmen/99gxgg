/* pages/tracking/index.wxss */
.tracking-page {
  padding-bottom: 64rpx;
  background-color: var(--surface-2);
  min-height: 100vh;
}

/* Tab Switcher (Premium) */
.tab-switcher-container {
  position: sticky;
  top: 0;
  z-index: 100;
  background: white;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.premium-tabs {
  display: flex;
  background: #F2F3F5;
  border-radius: 40rpx;
  padding: 8rpx;
  gap: 8rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: var(--text-muted);
  transition: all 0.3s var(--ease);
}

.tab-item.active {
  background: white;
  color: var(--primary);
  font-weight: 700;
  box-shadow: var(--shadow-xs);
}

.tab-icon { font-size: 28rpx; }

/* Orders List */
.orders-container { padding: 32rpx; }

.empty-state {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 100rpx 0;
}

.order-accordion {
  margin-bottom: 24rpx;
  padding: 0 !important;
  overflow: hidden;
  transition: all 0.3s var(--spring);
}
.order-accordion.expanded-mode {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
  border: 1rpx solid rgba(15, 130, 101, 0.1);
}

.order-summary {
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-id-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.order-id-tag { font-size: 20rpx; background: #F0F2F5; color: #666; padding: 4rpx 12rpx; border-radius: 6rpx; font-weight: 700; }
.order-date { font-size: 20rpx; color: #BBB; }
.order-title { font-size: 30rpx; font-weight: 700; color: var(--text-h); }

.order-status-area { display: flex; align-items: center; gap: 16rpx; }
.status-pill { font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 24rpx; font-weight: 600; }
.status-pill.processing { background: #E3F2FD; color: #1E88E5; }
.status-pill.completed { background: #E8F5EE; color: #0F8265; }
.status-pill.pending { background: #F5F7FA; color: #999; }

.chevron { font-size: 18rpx; color: #CCC; transition: transform 0.3s; }
.chevron.rotated { transform: rotate(180deg); }

/* Timeline Body */
.order-details-body {
  padding: 0 40rpx 40rpx;
  background: #FAFBFC;
}

.timeline-container {
  padding-top: 32rpx;
  display: flex;
  flex-direction: column;
}

.timeline-step { display: flex; gap: 24rpx; position: relative; padding-bottom: 40rpx; }
.timeline-step:last-child { padding-bottom: 0; }

.step-marker {
  width: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.marker-icon {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700;
  z-index: 2;
}
.marker-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #DDD; margin-top: 12rpx; z-index: 2;
}
.marker-line {
  position: absolute; left: 19rpx; top: 40rpx; bottom: -40rpx;
  width: 2rpx; background: #EEE; z-index: 1;
}

.timeline-step.completed .marker-icon { background: #E8F5EE; color: #0F8265; }
.timeline-step.completed .marker-line { background: #0F8265; opacity: 0.3; }
.timeline-step.processing .marker-icon { background: #E3F2FD; color: #1E88E5; box-shadow: 0 0 16rpx rgba(30,136,229,0.3); }

.step-content { flex: 1; padding-top: 4rpx; }
.step-title { font-size: 26rpx; font-weight: 600; color: #333; margin-bottom: 4rpx; }
.step-time { font-size: 20rpx; color: #999; }

.timeline-step.processing .step-title { color: #1E88E5; }
.timeline-step.pending .step-title { color: #999; }
