/* pages/materials/index.wxss */
.materials-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--surface-2);
}

.search-bar-container {
  background: white;
  padding: 24rpx 32rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid var(--border);
}

.premium-search {
  background: #F2F3F5;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  gap: 16rpx;
}
.premium-search input {
  flex: 1;
  font-size: 26rpx;
}

.materials-layout {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* Sidebar */
.sidebar {
  width: 180rpx;
  background: #F7F8FA;
  height: 100%;
}
.sidebar-item {
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-muted);
  position: relative;
}
.sidebar-item.active {
  background: white;
  color: var(--primary);
  font-weight: 700;
}
.sidebar-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 25%;
  height: 50%;
  width: 8rpx;
  background: var(--primary);
  border-radius: 0 4rpx 4rpx 0;
}
.sidebar-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 12rpx;
  height: 12rpx;
  background: var(--primary);
  border-radius: 50%;
}

/* Product Area */
.product-area {
  flex: 1;
  height: 100%;
  padding: 32rpx;
  background: white;
}
.category-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
}
.ct-main { font-size: 32rpx; font-weight: 700; color: var(--text-h); }
.ct-sub { font-size: 20rpx; color: var(--text-muted); margin-top: 4rpx; }

/* Product Card */
.product-card {
  margin-bottom: 32rpx;
  padding: 32rpx;
  border: 1px solid rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
}
.product-card.active-item {
  border-color: var(--primary);
  background: #F0F9F6;
}
.in-cart-pill {
  position: absolute;
  top: 0; right: 0;
  background: var(--primary);
  color: white;
  font-size: 18rpx;
  padding: 4rpx 16rpx;
  border-radius: 0 0 0 16rpx;
}

.p-top {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.p-img {
  width: 96rpx; height: 96rpx;
  background: #F5F7FA;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
.p-name { font-size: 28rpx; font-weight: 700; display: block; margin-bottom: 4rpx; }
.p-mfr, .p-model { font-size: 20rpx; color: var(--text-muted); display: block; line-height: 1.4; }

.crowd-box {
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
}
.crowd-meta { display: flex; justify-content: space-between; font-size: 18rpx; color: #888; margin-bottom: 12rpx; }
.progress-bg { height: 8rpx; background: #EEE; border-radius: 4rpx; margin-bottom: 12rpx; }
.progress-fill { height: 100%; background: var(--primary); border-radius: 4rpx; }
.crowd-stats { display: flex; justify-content: space-between; font-size: 20rpx; color: #444; }
.diff { color: #E64A19; font-weight: 600; }

.price-row { display: flex; justify-content: space-between; align-items: flex-end; }
.p-label { font-size: 18rpx; color: #888; display: block; }
.p-val { font-size: 24rpx; color: #E64A19; font-weight: 700; }
.huge { font-size: 36rpx; }
.p-old { font-size: 18rpx; text-decoration: line-through; color: #BBB; }
.join-btn {
  background: #E64A19; color: white;
  font-size: 24rpx; font-weight: 700;
  padding: 12rpx 32rpx; border-radius: 32rpx;
  margin: 0;
}
.join-btn.in { background: #E8F5EE; color: var(--primary); border: 1px solid var(--primary); }

/* Procurement Requests */
.request-card { padding: 32rpx; margin-bottom: 24rpx; }
.rq-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.rq-cat { font-size: 20rpx; background: #E3F2FD; color: #1E88E5; padding: 4rpx 16rpx; border-radius: 4rpx; }
.rq-time { font-size: 18rpx; color: #BBB; }
.rq-title { font-size: 28rpx; font-weight: 700; margin-bottom: 12rpx; }
.rq-specs, .rq-price { font-size: 22rpx; color: #666; margin-bottom: 4rpx; }
.rq-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 24rpx; border-top: 1rpx solid #F0F0F0; padding-top: 24rpx; }
.rq-buyer { display: flex; flex-direction: column; }
.rq-name { font-size: 24rpx; font-weight: 600; }
.rq-project { font-size: 18rpx; color: #999; }
.rq-btn { background: var(--primary); color: white; font-size: 22rpx; padding: 8rpx 24rpx; border-radius: 8rpx; margin: 0; }

/* Floating Cart Bar */
.floating-cart {
  position: fixed;
  bottom: 160rpx; left: 32rpx; right: 32rpx;
  background: white; border-radius: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
  display: flex; align-items: center;
  padding: 24rpx 32rpx;
  z-index: 500;
  transform: translateY(200rpx);
  opacity: 0;
  transition: all 0.3s var(--spring);
}
.floating-cart.active {
  transform: translateY(0);
  opacity: 1;
}

.cart-icon-wrap { position: relative; width: 64rpx; height: 64rpx; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; border-radius: 16rpx; margin-right: 24rpx; }
.icon-cart { font-size: 32rpx; }
.cart-badge { position: absolute; top: -12rpx; right: -12rpx; background: #E64A19; color: white; font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 12rpx; }

.estimate-text { flex: 1; display: flex; flex-direction: column; }
.et-total { font-size: 26rpx; font-weight: 700; color: var(--text-h); }
.et-sub { font-size: 18rpx; color: var(--text-muted); }
.view-cart-btn { background: #E64A19; color: white; font-size: 24rpx; font-weight: 700; padding: 12rpx 32rpx; border-radius: 8rpx; margin: 0; }

/* Modals & Sheets (Same base as Steel) */
.modal-backdrop {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); backdrop-filter: blur(8rpx); z-index: 1000;
}
.bottom-sheet {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: white; border-radius: 48rpx 48rpx 0 0; z-index: 1001;
  padding: 40rpx 32rpx 80rpx;
}
.sheet-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; }
.sh-prod { display: flex; align-items: center; gap: 24rpx; }
.sh-emoji { font-size: 64rpx; background: #F5F7FA; padding: 20rpx; border-radius: 24rpx; }
.sh-info { display: flex; flex-direction: column; gap: 4rpx; }
.sh-name { font-size: 32rpx; font-weight: 700; }
.sh-price { font-size: 26rpx; }
.close-btn { font-size: 48rpx; color: #BBB; line-height: 1; }

.sheet-section { padding: 32rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.no-border { border: none; }
.sec-title { font-size: 26rpx; font-weight: 700; color: var(--text-h); display: block; margin-bottom: 24rpx; }
.opt-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; font-size: 26rpx; }
.opt-sub { font-size: 20rpx; color: var(--text-muted); display: block; }
.qty-control input { background: #F9FAFB; height: 88rpx; border-radius: 16rpx; padding: 0 32rpx; width: 100%; border: 1rpx solid #EEE; text-align: center; }
.add-cart-btn { background: #E64A19; color: white; font-weight: 700; border-radius: 48rpx; height: 96rpx; margin-top: 48rpx; }

.cart-list { max-height: 50vh; }
.cart-item { display: flex; align-items: center; padding: 32rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.ci-img { font-size: 48rpx; margin-right: 24rpx; }
.ci-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.ci-name { font-size: 26rpx; font-weight: 700; }
.ci-meta { font-size: 22rpx; color: var(--text-muted); }
.ci-tags { display: flex; gap: 8rpx; }
.ci-tags .tag { font-size: 16rpx; background: #F5F7FA; color: #999; padding: 2rpx 8rpx; border-radius: 4rpx; }
.ci-del { font-size: 22rpx; color: #E64A19; }

.sheet-footer { padding-top: 48rpx; }
.cart-total-info { text-align: right; margin-bottom: 32rpx; font-size: 32rpx; font-weight: 700; color: #E64A19; }
.checkout-btn { background: #E64A19; color: white; height: 96rpx; border-radius: 48rpx; font-weight: 700; }
