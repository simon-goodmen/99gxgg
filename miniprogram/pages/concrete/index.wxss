/* pages/concrete/index.wxss */
.concrete-page {
  padding-bottom: 64rpx;
  background-color: var(--surface-2);
}

.main-content {
  padding: 32rpx;
}

/* ── Dashboard Card Upgrade ────────────────────── */
.dashboard-card.premium-card {
  position: relative;
  background: linear-gradient(135deg, #116854 0%, #0A4D3E 100%);
  border-radius: var(--radius-xl);
  padding: 48rpx 40rpx;
  overflow: hidden;
  border: none;
}

.card-accent {
  position: absolute;
  top: -100rpx; right: -100rpx;
  width: 300rpx; height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.dash-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; }
.factory-selector-pill {
  display: flex; align-items: center; gap: 16rpx;
  background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(16rpx);
  padding: 12rpx 28rpx; border-radius: 40rpx; border: 1px solid rgba(255,255,255,0.1);
}
.fs-name { font-size: 26rpx; font-weight: 600; color: white; }
.chevron { font-size: 18rpx; color: white; opacity: 0.8; }

.live-indicator {
  display: flex; align-items: center; gap: 12rpx;
  background: rgba(0,0,0,0.2); padding: 8rpx 24rpx; border-radius: 24rpx;
}
.status-lbl { font-size: 22rpx; font-weight: 600; color: #81C784; }

/* Grade Selector */
.dash-grade-selector {
  white-space: nowrap;
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.grade-item {
  display: inline-block;
  padding: 8rpx 28rpx; border-radius: 28rpx; font-size: 24rpx; font-weight: 600;
  border: 2rpx solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.7);
  margin-right: 16rpx;
}
.grade-item.active {
  border-color: #FFD700; background: rgba(255,215,0,0.15); color: #FFD700;
}

.price-tag-highlight {
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(90deg, #FFD700 0%, #FFA000 100%);
  color: #0A4D3E; font-weight: 800; font-size: 48rpx;
  padding: 8rpx 32rpx; border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 215, 0, 0.3);
}
.small-unit { font-size: 24rpx; font-weight: 400; margin-left: 8rpx; }

.flex-slogan { display: flex; align-items: center; gap: 24rpx; margin-bottom: 48rpx; }
.slogan-text-group { display: flex; flex-direction: column; gap: 4rpx; flex: 1; }
.slogan-line1 { font-size: 26rpx; font-weight: 500; color: rgba(255,255,255,0.95); text-align: right;}
.slogan-line2 { font-size: 22rpx; opacity: 0.8; color: rgba(255,255,255,0.85); text-align: right; border-right: 4rpx solid #FFD700; padding-right: 16rpx;}

.dash-tag-list { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 48rpx; }
.info-tag { font-size: 22rpx; background: rgba(255,255,255,0.1); color: white; padding: 8rpx 20rpx; border-radius: 12rpx; }

.feature-highlights { display: flex; justify-content: space-between; gap: 16rpx; }
.stat-box { flex: 1; background: rgba(255,255,255,0.08); padding: 24rpx 8rpx; border-radius: 24rpx; text-align: center; display: flex; flex-direction: column; }
.stat-num { font-size: 28rpx; font-weight: 800; color: white; margin-bottom: 4rpx; }
.unit { font-size: 18rpx; font-weight: 400; }
.stat-label { font-size: 18rpx; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.4rpx; }

/* ── Section Header ────────────────────────────── */
.section-header { margin: 80rpx 0 40rpx; display: flex; flex-direction: column; gap: 8rpx; }
.sh-title { font-size: 36rpx; font-weight: 800; color: #0A4D3E; }
.sh-accent { width: 64rpx; height: 8rpx; background: #FFD700; border-radius: 4rpx; }

/* ── Order Form ───────────────────────────────── */
.order-form-card { padding: 40rpx !important; }
.form-group { margin-bottom: 32rpx; }
.form-row { display: flex; gap: 24rpx; margin-bottom: 32rpx; }
.form-item.half { flex: 1; }
.label { font-size: 24rpx; color: var(--text-muted); margin-bottom: 12rpx; display: block; }
.req { color: #E53935; }
.picker-val, input {
  height: 80rpx; background: #F9FAFB; border: 2rpx solid #EEE; border-radius: 16rpx;
  padding: 0 24rpx; font-size: 28rpx; color: var(--text-h);
  display: flex; align-items: center;
}
.add-btn {
  width: 100%; height: 88rpx; background: #E8F5EE; color: #0F8265;
  border: 1px solid #0F8265; border-radius: 16rpx; font-size: 28rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}

/* ── Cart Card ────────────────────────────────── */
.total-qty { color: #E53935; font-size: 26rpx; font-weight: 700; }
.list-header { display: flex; justify-content: space-between; font-weight: 700; margin-bottom: 32rpx; }

.order-list { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.order-item { background: #F9FAFB; padding: 24rpx; border-radius: 16rpx; border: 2rpx solid #EEE; }
.oi-main { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.oi-grade { font-weight: 700; color: #333; font-size: 28rpx; }
.oi-qty { font-weight: 700; color: #0F8265; font-size: 28rpx; }
.oi-sub { display: flex; justify-content: space-between; font-size: 22rpx; color: #888; margin-bottom: 12rpx; }
.oi-del { color: #E53935; }
.oi-address { font-size: 22rpx; color: #0F8265; background: #E8F5EE; padding: 12rpx 16rpx; border-radius: 8rpx; border-left: 6rpx solid #0F8265; }
.empty-state { text-align: center; color: #999; font-size: 26rpx; padding: 48rpx 0; }

.grab-btn {
  width: 100%; height: 112rpx; background: #0F8265; color: white;
  border: none; border-radius: 24rpx; font-size: 32rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}

/* ── Overview List ────────────────────────────── */
.ov-item { padding: 32rpx !important; margin-bottom: 16rpx !important; }
.ov-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.ov-name { font-size: 28rpx; font-weight: 700; }

.progress-bar-small { background: #EEE; height: 12rpx; border-radius: 6rpx; overflow: hidden; margin-bottom: 16rpx; }
.progress-fill-small { height: 100%; }
.ov-nums { display: flex; justify-content: space-between; font-size: 22rpx; }
.ov-quota { font-weight: 600; }
.ov-remain { color: #0F8265; font-weight: 600; }

/* Modals */
.modal-backdrop {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); backdrop-filter: blur(8rpx); z-index: 1000;
}
.bottom-sheet {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: white; border-radius: 48rpx 48rpx 0 0; z-index: 1001;
  padding: 40rpx 32rpx 80rpx;
}
.sheet-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; }
.sheet-title { font-size: 34rpx; font-weight: 700; }
/* Reuse factory-list styles from Steel if needed, otherwise define here */
.factory-item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx; background: #F9FAFB; border-radius: 24rpx; margin-bottom: 16rpx; }
.factory-item.active { background: #F0F9F6; border-color: var(--primary); }
.f-name { font-size: 28rpx; font-weight: 700; }
.f-meta { font-size: 20rpx; color: #999; margin-top: 4rpx; display: flex; gap: 12rpx; }

/* Center Modal */
.center-modal { display: flex; align-items: center; justify-content: center; }
.center-card { background: white; width: 85%; border-radius: 32rpx; padding: 48rpx; }
.modal-title { font-size: 32rpx; font-weight: 700; }
.modal-input {
  height: 96rpx; background: #F9FAFB; border: 2rpx solid #DDD; border-radius: 16rpx;
  padding: 0 24rpx; margin-bottom: 24rpx; margin-top: 24rpx; font-size: 28rpx;
}
.submit-btn {
  background: #E53935; color: white; height: 96rpx; border-radius: 48rpx; font-size: 30rpx; font-weight: 700;
}
