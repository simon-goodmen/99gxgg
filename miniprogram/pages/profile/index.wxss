/* pages/profile/index.wxss */
.profile-page {
  min-height: 100vh;
  background-color: var(--surface-2);
  padding-bottom: 64rpx;
}

/* ── Premium Header ─────────────────────────── */
.profile-header-premium {
  position: relative;
  background: linear-gradient(135deg, #0F8265 0%, #0A4D3E 100%);
  padding: 100rpx 40rpx 140rpx;
  color: white;
  overflow: hidden;
}

.header-overlay-radial {
  position: absolute;
  top: -50%; right: -20%;
  width: 600rpx; height: 600rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.user-profile-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 1;
}

.upb-left {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar-large-glow {
  width: 120rpx; height: 120rpx;
  background: rgba(255,255,255,0.2);
  border: 4rpx solid rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  box-shadow: 0 0 40rpx rgba(255,255,255,0.1);
}

.user-name-group { display: flex; flex-direction: column; }
.user-name-row { display: flex; align-items: center; gap: 16rpx; }
.h2 { font-size: 36rpx; font-weight: 700; }
.pro-badge { font-size: 18rpx; background: #FFD700; color: #0A4D3E; padding: 4rpx 12rpx; border-radius: 20rpx; font-weight: 700; }
.partner-id { font-size: 20rpx; opacity: 0.6; margin-top: 8rpx; }

.settings-icon-btn { font-size: 40rpx; }

.login-invitation {
  margin-top: 48rpx;
  background: rgba(255,255,255,0.1);
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid rgba(255,255,255,0.05);
}
.li-label { font-size: 26rpx; font-weight: 600; }
.li-action { font-size: 22rpx; opacity: 0.8; }

/* ── Main Content ─────────────────────────── */
.profile-content {
  padding: 0 32rpx;
  margin-top: -80rpx;
  position: relative;
  z-index: 2;
}

.publish-req-btn {
  background: white; color: var(--primary);
  width: 100%; height: 112rpx;
  border-radius: 32rpx; border: 4rpx solid var(--primary);
  font-size: 30rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  gap: 16rpx; box-shadow: var(--shadow-md);
  margin-bottom: 40rpx;
}

.stats-row {
  display: flex; gap: 24rpx; margin-bottom: 48rpx;
}
.stat-item {
  flex: 1; background: white; padding: 32rpx; border-radius: 24rpx;
  text-align: center; box-shadow: var(--shadow-xs);
}
.stat-item .num { font-size: 36rpx; font-weight: 800; color: var(--primary); margin-bottom: 4rpx; }
.stat-item .label { font-size: 18rpx; color: var(--text-muted); }

/* ── Section Headers ─────────────────────────── */
.section-header { margin: 48rpx 0 24rpx; display: flex; justify-content: space-between; align-items: baseline; }
.sh-title { font-size: 32rpx; font-weight: 700; color: var(--text-h); }
.sh-title.op-light { opacity: 0.5; font-size: 24rpx; }
.sh-link { font-size: 22rpx; color: var(--primary); font-weight: 600; }

/* ── Requirement Cards ───────────────────────── */
.req-card-professional { padding: 32rpx !important; margin-bottom: 24rpx; }
.req-header { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.req-id { font-size: 18rpx; color: var(--text-muted); font-weight: 700; }
.req-tag { font-size: 18rpx; color: var(--primary); background: #E8F5EE; padding: 4rpx 16rpx; border-radius: 20rpx; }
.req-title { font-size: 28rpx; font-weight: 700; margin-bottom: 16rpx; }
.req-specs { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 24rpx; }
.spec-tag { font-size: 18rpx; background: #F5F7FA; color: #666; padding: 4rpx 12rpx; border-radius: 8rpx; }
.spec-tag.price { color: #E64A19; font-weight: 700; }

.req-footer { border-top: 1rpx solid #F0F0F0; padding-top: 24rpx; display: flex; justify-content: space-between; align-items: center; }
.req-status { font-size: 22rpx; color: var(--text-muted); }
.req-action { font-size: 22rpx; color: var(--primary); font-weight: 700; }

/* ── Project Ledger ──────────────────────────── */
.project-ledger-row { padding: 32rpx !important; display: flex; align-items: center; gap: 24rpx; margin-bottom: 16rpx; }
.plr-main { flex: 1; }
.plr-name { font-size: 26rpx; font-weight: 700; display: block; }
.plr-meta { font-size: 18rpx; color: var(--text-muted); }
.plr-progress-box { text-align: right; }
.plr-val { font-size: 24rpx; font-weight: 800; color: #E64A19; display: block; }
.plr-label { font-size: 18rpx; color: #999; }

/* ── Menu Group ──────────────────────────────── */
.menu-card { padding: 0 !important; overflow: hidden; }
.menu-item-premium {
  padding: 32rpx; display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1rpx solid #F6F7F9;
}
.menu-item-premium:last-child { border-bottom: none; }
.mip-left { display: flex; align-items: center; gap: 24rpx; }
.mip-icon { width: 80rpx; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.industrial-orange { background: #FFF3E0; color: #E65100; }
.industrial-green { background: #E8F5EE; color: #0F8265; }

.mip-info { display: flex; flex-direction: column; }
.mip-text { font-size: 26rpx; font-weight: 700; color: var(--text-h); }
.mip-sub { font-size: 18rpx; color: var(--text-muted); }

.logout-link { text-align: center; margin-top: 64rpx; font-size: 24rpx; color: #E53935; opacity: 0.6; }

/* ── Settings View ───────────────────────────── */
.settings-view {
  position: fixed; inset: 0; background: var(--surface-2); z-index: 1000;
  display: flex; flex-direction: column; overflow-y: auto;
}
.settings-header {
  background: white; padding: 48rpx 32rpx; display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1rpx solid var(--border);
}
.sh-title { font-size: 32rpx; font-weight: 700; }
.settings-back-btn { font-size: 26rpx; font-weight: 600; color: var(--primary); }

.settings-body { padding: 32rpx; flex: 1; }
.settings-section { margin-bottom: 48rpx; }
.section-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.section-title { font-size: 26rpx; font-weight: 700; color: #999; margin-bottom: 16rpx; display: flex; gap: 12rpx; }

.settings-card { padding: 0 32rpx !important; }
.field { padding: 32rpx 0; border-bottom: 1rpx solid #F0F0F0; display: flex; justify-content: space-between; align-items: center; }
.field.no-border { border-bottom: none; }
.field .label { font-size: 26rpx; color: var(--text-h); }
.field input { text-align: right; font-size: 26rpx; color: var(--text-muted); }

.project-detail-card { padding: 32rpx !important; margin-bottom: 16rpx; }
.pdc-header { display: flex; justify-content: space-between; align-items: center; }
.pdc-left { display: flex; align-items: center; gap: 20rpx; }
.pdc-dot { width: 12rpx; height: 12rpx; background: var(--primary); border-radius: 50%; }
.pdc-name { font-size: 26rpx; font-weight: 700; display: block; }
.pdc-company { font-size: 20rpx; color: #999; }

.pdc-detail { margin-top: 32rpx; border-top: 1rpx solid #F0F0F0; padding-top: 24rpx; }
.pdc-row { font-size: 22rpx; color: #666; margin-bottom: 12rpx; }
.pdc-row.sub { color: #BBB; padding-left: 32rpx; }
.pdc-divider { height: 1rpx; background: #EEE; margin: 16rpx 0; }
.pdc-delete { color: #E53935; font-size: 22rpx; text-align: center; margin-top: 24rpx; border-top: 1rpx solid #FEE; padding-top: 16rpx; }

.save-settings-btn { background: var(--primary); color: white; border-radius: 48rpx; height: 96rpx; font-weight: 700; margin-top: 48rpx; }

/* ── Publish Modal ── */
.publish-sheet { padding-top: 40rpx; }
.form-row { display: flex; gap: 24rpx; margin-bottom: 24rpx; }
.form-item.half { flex: 1; }
.label { font-size: 22rpx; color: #999; margin-bottom: 8rpx; display: block; }
.picker-val, .publish-sheet input { height: 88rpx; background: #F9FAFB; border-radius: 16rpx; border: 1rpx solid #EEE; padding: 0 24rpx; font-size: 26rpx; display: flex; align-items: center; }
.price-chips { display: flex; gap: 16rpx; margin-top: 8rpx; }
.chip { padding: 12rpx 32rpx; background: #F5F7FA; border-radius: 32rpx; font-size: 24rpx; color: #666; }
.chip.active { background: #E8F5EE; color: var(--primary); border: 1rpx solid var(--primary); }
.publish-btn { background: var(--primary); color: white; border-radius: 48rpx; height: 96rpx; font-weight: 700; margin-top: 64rpx; }
