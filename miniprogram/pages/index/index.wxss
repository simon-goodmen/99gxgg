/**index.wxss**/
page {
  background-color: var(--surface-2);
}

.container {
  padding-bottom: 64rpx;
}

/* ── Hero Section ────────────────────────────────── */
.hero-section {
  position: relative;
  padding: 80rpx 40rpx 120rpx;
  background: linear-gradient(135deg, #0A4D3E 0%, #116854 100%);
  color: white;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.brand-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 20rpx;
  background: rgba(255, 215, 0, 0.2);
  color: #FFD700;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
  border: 1px solid rgba(255, 215, 0, 0.3);
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  font-weight: 400;
}

/* ── Stats Bar ───────────────────────────────────── */
.stats-bar {
  display: flex;
  justify-content: space-between;
  background: white;
  margin: -60rpx 32rpx 0;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1px solid var(--border);
}

.stat-item:last-child {
  border-right: none;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--primary);
}

.stat-unit {
  font-size: 20rpx;
  margin-left: 4rpx;
}

.stat-label {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* ── Section Header ──────────────────────────────── */
.main-content {
  padding: 40rpx 32rpx;
}

.section-header {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-h);
  display: block;
}

.section-subtitle {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* ── Services List ───────────────────────────────── */
.services-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.service-card {
  display: flex;
  align-items: center;
  background: white;
  padding: 32rpx;
  border-radius: 32rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s;
  border: 1px solid transparent;
}

.service-card:active {
  transform: scale(0.98);
  border-color: var(--primary);
  background: var(--primary-light);
}

.service-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.service-icon {
  font-size: 48rpx;
}

.service-info {
  flex: 1;
}

.service-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.service-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-h);
}

.service-sub-tag {
  font-size: 18rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.service-desc {
  font-size: 20rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

.arrow-wrap {
  color: var(--border);
  font-size: 32rpx;
  margin-left: 20rpx;
}

/* ── Support Card ────────────────────────────────── */
.support-card {
  background: linear-gradient(135deg, white 0%, #F0F9F6 100%);
  margin-bottom: 48rpx;
}

.support-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.support-text {
  flex: 1;
}

.support-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0A4D3E;
  display: block;
}

.support-desc {
  font-size: 18rpx;
  color: #666;
}

.support-btn {
  background: var(--primary);
  color: white;
  font-size: 22rpx;
  font-weight: 700;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  margin-left: 24rpx;
}

/* ── Footer ──────────────────────────────────────── */
.footer-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 40rpx 0;
}

.footer-info text {
  font-size: 18rpx;
  color: #CCC;
}

