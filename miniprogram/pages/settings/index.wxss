/* Settings Page Styles */
.settings-page { background: #F8F9FA; min-height: 100vh; }

.settings-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 40rpx; background: linear-gradient(135deg, #0A4D3C 0%, #063328 100%); color: white; position: sticky; top: 0; z-index: 100; }
.settings-title { font-size: 34rpx; font-weight: 800; }
.settings-back-btn { background: rgba(255,255,255,0.1); border: 2rpx solid rgba(255,255,255,0.1); border-radius: 16rpx; overflow: hidden; }
.back-nav { color: white; font-size: 26rpx; font-weight: 600; padding: 16rpx 24rpx; display: block; }

.settings-body { padding: 40rpx 32rpx 120rpx; }

/* Sections */
.settings-section { margin-bottom: 56rpx; }
.section-title { font-size: 28rpx; font-weight: 800; color: #495057; margin: 0 0 24rpx 8rpx; display: block; }
.section-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.section-row .section-title { margin: 0; }

.add-project-btn { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 24rpx; border-radius: 16rpx; font-size: 24rpx; font-weight: 700; background: #E6F6F1; color: #0F8265; border: 2rpx solid rgba(15,130,101,0.15); }

/* Settings Card */
.settings-card { background: white; border-radius: 32rpx; padding: 8rpx 0; border: 2rpx solid rgba(0,0,0,0.04); box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03); }
.settings-field { display: flex; flex-direction: column; gap: 8rpx; padding: 28rpx 40rpx; border-bottom: 2rpx solid #F8F9FA; }
.settings-field:last-child { border-bottom: none; }
.field-label { font-size: 22rpx; font-weight: 700; color: #8E929E; text-transform: uppercase; letter-spacing: 1rpx; }
.settings-field input { border: none; background: transparent; font-size: 30rpx; font-weight: 700; color: #1A1D23; padding: 8rpx 0; }

/* New Project Form */
.new-project-form { background: white; border-radius: 28rpx; padding: 32rpx; margin-bottom: 24rpx; border: 4rpx dashed rgba(15,130,101,0.2); }
.npf-field { margin-bottom: 24rpx; }
.npf-label { display: block; font-size: 22rpx; font-weight: 700; color: #8E929E; margin-bottom: 8rpx; text-transform: uppercase; letter-spacing: 0.5rpx; }
.npf-field input { width: 100%; box-sizing: border-box; padding: 20rpx 24rpx; border: 2rpx solid #DEE2E6; border-radius: 16rpx; font-size: 28rpx; font-weight: 600; color: #333; background: #FAFBFC; }
.npf-actions { display: flex; gap: 16rpx; margin-top: 8rpx; }
.npf-cancel { flex: 1 !important; padding: 20rpx !important; border-radius: 16rpx; font-size: 26rpx; font-weight: 700; background: #F1F3F5 !important; color: #6C757D !important; }
.npf-confirm { flex: 2 !important; padding: 20rpx !important; border-radius: 16rpx; font-size: 26rpx; font-weight: 700; background: #0F8265 !important; color: white !important; }

/* Project Detail Card */
.project-detail-card { background: white; border-radius: 24rpx; margin-bottom: 20rpx; border: 2rpx solid rgba(0,0,0,0.04); box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.02); overflow: hidden; }
.pdc-header { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 32rpx; }
.pdc-left { display: flex; align-items: center; gap: 24rpx; }
.pdc-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #0F8265; flex-shrink: 0; }
.pdc-name { font-size: 28rpx; font-weight: 800; color: #1A1D23; display: block; }
.pdc-company { font-size: 22rpx; color: #8E929E; font-weight: 600; display: block; }
.pdc-arrow { font-size: 32rpx; color: #CCC; transition: transform 0.2s; }
.pdc-arrow.rotated { transform: rotate(90deg); }

.pdc-detail { padding: 0 32rpx 28rpx 72rpx; border-top: 2rpx solid #F5F5F5; }
.pdc-row { font-size: 24rpx; color: #6C757D; font-weight: 600; padding: 12rpx 0; }
.pdc-row.muted { opacity: 0.5; }
.pdc-divider { height: 2rpx; background: #F1F3F5; margin: 12rpx 0; }
.pdc-delete { display: flex; align-items: center; gap: 8rpx; margin-top: 20rpx; padding: 12rpx 20rpx; font-size: 22rpx; font-weight: 700; color: #DC3545; background: #FFF5F5; border: 2rpx solid rgba(220,53,69,0.1); border-radius: 12rpx; width: fit-content; }

/* Save Button */
.settings-save-btn { width: 100% !important; display: flex; align-items: center; justify-content: center; gap: 16rpx; padding: 32rpx !important; background: linear-gradient(135deg, #0F8265, #0A6B53) !important; color: white !important; border: none; border-radius: 28rpx; font-size: 30rpx; font-weight: 800; box-shadow: 0 16rpx 48rpx rgba(15,130,101,0.2); margin-bottom: 32rpx; }

.logout-action { text-align: center; color: #8E929E; font-size: 24rpx; padding: 32rpx; }
