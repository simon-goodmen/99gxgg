page {
  background: #F5F7FA;
}

.contact-page {
  padding: 32rpx;
}

.hero {
  padding: 40rpx 24rpx 32rpx;
  background: linear-gradient(135deg, #0A4D3E 0%, #116854 100%);
  border-radius: 28rpx;
  color: #fff;
  margin-bottom: 28rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.hero-sub {
  font-size: 22rpx;
  opacity: 0.85;
  line-height: 1.5;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 130, 101, 0.08);
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 12rpx;
}

input,
textarea {
  width: 100%;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  font-size: 26rpx;
  color: #111827;
}

textarea {
  min-height: 220rpx;
}

.submit-btn {
  margin-top: 12rpx;
  background: #0F8265;
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  padding: 18rpx 0;
}
