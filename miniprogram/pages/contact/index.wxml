<view class="contact-page">
  <view class="hero">
    <text class="hero-title">在线咨询</text>
    <text class="hero-sub">留下姓名和手机号，需求会实时进入 Web 后台</text>
  </view>

  <view class="form-card">
    <view class="field">
      <text class="label">姓名 *</text>
      <input placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
    </view>
    <view class="field">
      <text class="label">手机号 *</text>
      <input type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="field">
      <text class="label">需求说明</text>
      <textarea placeholder="例：想咨询商砼价格、钢构加工排期、建材供应等" value="{{message}}" bindinput="onMessageInput" />
    </view>
    <button class="submit-btn" bindtap="submitLead">提交到后台</button>
  </view>
</view>
