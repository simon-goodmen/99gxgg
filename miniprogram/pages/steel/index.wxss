/* pages/steel/index.wxss */
.home-page {
  padding-bottom: 64rpx;
  background-color: var(--surface-2);
}

.main-content {
  padding: 32rpx;
}

/* Dashboard Card Upgrade (1:1 with Web) */
.dashboard-card.premium-card {
  position: relative;
  background: linear-gradient(135deg, #116854 0%, #0A4D3E 100%);
  border-radius: var(--radius-xl);
  padding: 48rpx 40rpx;
  overflow: hidden;
  border: none;
}

.card-accent {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.dash-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.factory-selector-pill {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(16rpx);
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: 1px solid rgba(255,255,255,0.1);
}

.fs-name {
  font-size: 26rpx;
  font-weight: 600;
  color: white;
}

.chevron {
  font-size: 18rpx;
  color: white;
  opacity: 0.8;
}

.live-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(0,0,0,0.2);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.status-lbl {
  font-size: 22rpx;
  font-weight: 600;
  color: #81C784;
}

.flex-slogan {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.price-tag-highlight {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, #FFD700 0%, #FFA000 100%);
  color: #0A4D3E;
  font-weight: 800;
  font-size: 44rpx;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 215, 0, 0.3);
}

.slogan-text-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.slogan-line1 {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.95);
}

.slogan-line2 {
  font-size: 22rpx;
  opacity: 0.8;
  color: rgba(255,255,255,0.85);
  font-style: italic;
}

.dash-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.info-tag {
  background: rgba(255,255,255,0.1);
  color: white;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  border: 1px solid rgba(255,255,255,0.05);
}

.feature-highlights {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stat-box {
  flex: 1;
  background: rgba(255,255,255,0.08);
  padding: 24rpx 8rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(255,255,255,0.05);
  text-align: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.stat-num {
  font-size: 30rpx;
  font-weight: 800;
  color: white;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 18rpx;
  color: rgba(255,255,255,0.5);
  text-transform: uppercase;
  letter-spacing: 0.4rpx;
}

/* Section Header */
.section-header {
  margin: 80rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sh-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #0A4D3E;
  letter-spacing: -1rpx;
}

.sh-accent {
  width: 64rpx;
  height: 8rpx;
  background: #FFD700;
  border-radius: 4rpx;
}

/* Services Grid (2 Columns) */
.services-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
}

.service-card {
  width: calc(50% - 16rpx);
  background: white;
  border-radius: 36rpx;
  padding: 48rpx 32rpx;
  border: 1px solid rgba(15,130,101,0.08);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03);
  display: flex;
  flex-direction: column;
}

.svc-icon {
  width: 96rpx;
  height: 96rpx;
  background: #F0F9F6;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  font-size: 40rpx;
}

.svc-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0A4D3E;
  margin-bottom: 16rpx;
}

.svc-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
}

/* Capacity Section (Forest Green Card) */
.capacity-section {
  margin: 64rpx 0;
  padding: 48rpx;
  background: #0A4D3E;
  border-radius: 48rpx;
  color: white;
  box-shadow: 0 40rpx 80rpx rgba(10,77,62,0.15);
}

.capacity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.left-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-clock { font-size: 32rpx; }
.c-title { font-size: 34rpx; font-weight: 700; }

.month-tag {
  background: rgba(255,215,0,0.2);
  color: #FFD700;
  border: 1px solid rgba(255,215,0,0.3);
  font-size: 20rpx;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
}

.capacity-status-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 48rpx 32rpx;
  border-radius: 40rpx;
}

.status-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 48rpx;
}

.status-item { display: flex; flex-direction: column; gap: 8rpx; }
.s-label { font-size: 22rpx; color: rgba(255,255,255,0.6); }
.s-val { font-size: 32rpx; font-weight: 700; }
.s-val.primary { color: #FFD700; font-size: 36rpx; }
.unit { font-size: 20rpx; margin-left: 4rpx; font-weight: 400; }

.progress-bar {
  background: rgba(255,255,255,0.1);
  height: 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0F8265 0%, #FFD700 100%);
  box-shadow: 0 0 30rpx rgba(255,215,0,0.4);
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  margin-bottom: 32rpx;
}
.pl-left { color: #FFD700; }
.pl-right { color: rgba(255,255,255,0.5); }

.timeline-blocks {
  display: flex;
  gap: 16rpx;
}

.t-block {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: white;
}
.t-block.full { background: #FF5252; box-shadow: 0 4rpx 16rpx rgba(255,82,82,0.3); }
.t-block.warning { background: #FFD700; color: #0A4D3E; box-shadow: 0 4rpx 16rpx rgba(255,215,0,0.3); }
.t-block.available { background: #0F8265; box-shadow: 0 4rpx 16rpx rgba(15,130,101,0.3); }

/* CTA Button */
.book-now-section { padding-top: 48rpx; }
.book-btn-giant {
  width: 100%;
  height: 112rpx;
  background: linear-gradient(135deg, #0F8265 0%, #0A4D3E 100%);
  color: white;
  border-radius: 56rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(15,130,101,0.25);
  border: none;
}

/* Modals & Sheets */
.modal-backdrop {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
}

.bottom-sheet {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: white;
  border-radius: 48rpx 48rpx 0 0;
  z-index: 1001;
  padding: 40rpx 32rpx 80rpx;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 0 8rpx;
}
.sheet-title { font-size: 36rpx; font-weight: 700; color: var(--text-h); }
.close-btn { font-size: 48rpx; color: #BBB; line-height: 1; }

.factory-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: #F9FAFB;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
}
.factory-item.active {
  background: #F0F9F6;
  border-color: var(--primary);
}
.f-name { font-size: 30rpx; font-weight: 700; color: var(--text-h); }
.f-meta { font-size: 22rpx; color: var(--text-muted); margin-top: 8rpx; display: flex; gap: 16rpx; }
.f-check { color: var(--primary); font-size: 32rpx; font-weight: 700; }

.booking-form { padding-top: 24rpx; }
.form-item { margin-bottom: 32rpx; }
.label { font-size: 24rpx; color: var(--text-muted); margin-bottom: 12rpx; display: block; }
.form-item input, .picker-val {
  height: 96rpx; background: #F9FAFB; border-radius: 20rpx;
  padding: 0 24rpx; font-size: 28rpx; color: var(--text-h);
  display: flex; align-items: center;
}
.confirm-btn {
  background: var(--primary); color: white;
  height: 96rpx; border-radius: 48rpx; margin-top: 48rpx;
  font-size: 30rpx; font-weight: 700;
}
